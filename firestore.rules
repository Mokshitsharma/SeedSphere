rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price > 0 &&
             data.category in ['Vegetables', 'Fruits', 'Flowers', 'Grains'] &&
             data.image is string && data.image.size() < 500;
    }

    function isValidOrder(data) {
      return data.orderId is string &&
             data.amount is number && data.amount > 0 &&
             data.status in ['Pending', 'Paid', 'Failed'] &&
             data.customer is map &&
             data.items is list &&
             data.createdAt is timestamp;
    }

    // Products: Publicly readable, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if false; // Admin writes via console or backend
    }

    // Orders: Only backend (admin) should write, or restricted client write
    // For this demo, we'll allow client to create orders if they are valid
    match /orders/{orderId} {
      allow read: if true; // In production, restrict to owner or admin
      allow create: if isValidOrder(request.resource.data);
      allow update: if false; // Only backend updates status
    }
  }
}
